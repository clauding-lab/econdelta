__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/
.env

# Data and log snapshots — keep only .gitkeep sentinels
data/*/
logs/*/
logs/*.log
logs/*.stderr
logs/*.stdout
data/latest.json
!data/.gitkeep
!logs/.gitkeep
!data/*/.gitkeep
!logs/*/.gitkeep

# Graphify outputs
.graphifyignore
graphify-out/

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store

# Git worktrees
.worktrees/
